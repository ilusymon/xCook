.cook-page {
  min-height: 100vh;
  background: #FFF5F5;
  padding-bottom: 140rpx;
}

/* 菜品头部 */
.dish-header {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.dish-cover {
  width: 100%;
  height: 100%;
  border-radius: 0 0 32rpx 32rpx;
}

.dish-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  border-radius: 0 0 32rpx 32rpx;
}

.dish-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.dish-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.dish-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

/* 区段 */
.section {
  padding: 20rpx 24rpx;
}

.section-title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A3333;
}

.step-progress {
  font-size: 26rpx;
  color: #FF6B81;
  font-weight: 600;
  background: #FFE4E4;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.steps-timeline {
  padding-left: 8rpx;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -4rpx 20rpx rgba(255, 107, 129, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-btn {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.nav-btn.prev {
  color: #9B8888;
  background: #F5F0F0;
}

.nav-btn.prev.disabled {
  opacity: 0.4;
}

.nav-btn.video {
  color: #54A0FF;
  background: #E8F0FF;
}

.nav-btn.next {
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.3);
}

.nav-btn.next.done {
  background: linear-gradient(135deg, #5FD068, #7BE080);
  box-shadow: 0 4rpx 12rpx rgba(95, 208, 104, 0.3);
}
