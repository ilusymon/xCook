.cart-page {
  min-height: 100vh;
  background: #FFF5F5;
  padding-bottom: 140rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A3333;
}

.cart-list {
  padding: 16rpx 24rpx;
}

.cart-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 129, 0.06);
  position: relative;
}

.item-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3333;
}

.item-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.option-tag {
  font-size: 20rpx;
  color: #FF6B81;
  background: #FFE4E4;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.item-price {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #FFC048;
}

.coin-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FFF5F5;
  border: 2rpx solid #FFE4E4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FF6B81;
  font-weight: bold;
}

.qty-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #4A3333;
  min-width: 40rpx;
  text-align: center;
}

.delete-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #B0B0B0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 48rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #4A3333;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #9B8888;
}

/* 底部结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -4rpx 20rpx rgba(255, 107, 129, 0.1);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.checkout-info {
  flex: 1;
}

.checkout-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkout-label {
  font-size: 24rpx;
  color: #9B8888;
}

.checkout-cal {
  font-size: 22rpx;
  color: #FF9F43;
}

.checkout-price {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #FFC048;
}

.coin-icon-sm {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: #9B8888;
  padding: 12rpx 20rpx;
  margin-right: 16rpx;
}

.checkout-btn {
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.3);
}
