page {
  height: 100vh;
  overflow: hidden;
}

.menu-page {
  height: 100vh;
  background: #FFF5F5;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 129, 0.06);
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A3333;
}

.menu-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 180rpx;
  height: 100%;
  background: #FFFFFF;
  flex-shrink: 0;
}

.category-item {
  padding: 28rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #9B8888;
  position: relative;
  transition: color 0.25s ease, background-color 0.25s ease, font-weight 0.15s ease;
}

.category-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%) scaleY(0);
  width: 6rpx;
  height: 36rpx;
  background: #FF6B81;
  border-radius: 0 6rpx 6rpx 0;
  transition: transform 0.25s ease;
}

.category-item.active {
  color: #FF6B81;
  font-weight: 600;
  background: #FFF5F5;
}

.category-item.active::before {
  transform: translateY(-50%) scaleY(1);
}

/* 右侧菜品列表 */
.dish-list {
  flex: 1;
  height: 100%;
  min-width: 0;
  padding: 16rpx 20rpx;
  padding-bottom: 130rpx;
  box-sizing: border-box;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3333;
  padding: 16rpx 8rpx 12rpx;
}

.dish-group {
  margin-bottom: 16rpx;
}

.empty-hint {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #9B8888;
}
