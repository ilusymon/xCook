<view class="order-list-page">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <home-btn />
    <text class="page-title">我的订单</text>
  </view>

  <!-- 状态筛选 -->
  <view class="filter-tabs">
    <view
      class="filter-tab {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="onTabChange"
      data-index="{{index}}"
      data-value="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="orders" wx:if="{{orders.length > 0}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <view class="order-header">
        <text class="order-number">{{item.orderNumber}}</text>
        <order-status-tag status="{{item.status}}" />
      </view>
      <view class="order-items-summary">
        <text class="item-summary" wx:for="{{item.items}}" wx:for-item="dish" wx:key="dishId">
          {{dish.dishName}} x{{dish.quantity}}
        </text>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.createdAtText}}</text>
        <view class="order-total">
          <image class="coin-icon" src="/images/star-coin.png" />
          <text>{{item.totalPrice}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-emoji">📋</text>
    <text class="empty-text">暂无订单</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
    <text>加载更多</text>
  </view>
</view>
